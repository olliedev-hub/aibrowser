import sys
import os
from PyQt6.QtWidgets import (
    QApplication, 
    QMainWindow, 
    QTabWidget, 
    QToolBar, 
    QLineEdit, 
    QPushButton,
    QMessageBox,
    QComboBox
)
from PyQt6.QtCore import QUrl
from PyQt6.QtWebEngineWidgets import QWebEngineView
from PyQt6.QtWebEngineCore import QWebEngineProfile

# --- DARK THEME / CHROMIUM STYLE ---
CHROMIUM_STYLE = """
QMainWindow { background-color: #202124; }
QTabWidget::pane { border: 0; background: #202124; }
QTabBar::tab { 
    background: #35363A; color: #9aa0a6; padding: 8px 15px; 
    border-top-left-radius: 8px; border-top-right-radius: 8px; 
    margin-right: 2px; font-family: "Segoe UI", sans-serif; font-weight: bold;
}
QTabBar::tab:selected { background: #202124; color: #e8eaed; }
QToolBar { background: #292a2d; border-bottom: 1px solid #3c4043; padding: 6px; spacing: 8px; }
QLineEdit { 
    background-color: #303134; border-radius: 14px; border: 1px solid #5f6368; 
    color: #e8eaed; padding: 4px 14px; font-size: 14px; selection-background-color: #8ab4f8;
}
QPushButton { 
    background-color: transparent; color: #e8eaed; border-radius: 4px; 
    padding: 6px; font-weight: bold; font-size: 14px; 
}
QPushButton:hover { background-color: #3c4043; }
QComboBox {
    background-color: #303134; color: #e8eaed; border: 1px solid #5f6368;
    border-radius: 4px; padding: 4px; font-size: 12px;
}
QComboBox::drop-down { border: 0; }
"""

class BotHunterBrowser(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Bot Hunter - Secure Workstation")
        self.resize(1280, 850)

        # --- 1. SECURITY PROFILE SETUP ---
        # Isolate cookies to a local folder named 'browser_data'
        self.data_path = os.path.abspath(os.path.join(os.getcwd(), "browser_data"))
        
        self.profile = QWebEngineProfile.defaultProfile()
        self.profile.setPersistentStoragePath(self.data_path)
        self.profile.setCachePath(self.data_path)
        
        # Save the default Linux User Agent
        self.default_ua = self.profile.httpUserAgent()
        
        print(f"[*] SESSION ISOLATED: {self.data_path}")

        # --- 2. UI SETUP ---
        self.navbar = QToolBar()
        self.navbar.setMovable(False)
        self.addToolBar(self.navbar)

        # Navigation Buttons
        self.add_nav_btn("<", lambda: self.tabs.currentWidget().back())
        self.add_nav_btn(">", lambda: self.tabs.currentWidget().forward())
        self.add_nav_btn("⟳", lambda: self.tabs.currentWidget().reload())

        # URL Bar
        self.url_bar = QLineEdit()
        self.url_bar.setPlaceholderText("Search or Enter URL")
        self.url_bar.returnPressed.connect(self.navigate_to_url)
        self.navbar.addWidget(self.url_bar)

        # --- USER AGENT SWITCHER ---
        self.ua_selector = QComboBox()
        self.ua_selector.setFixedWidth(120)
        self.ua_selector.addItems(["Linux (Default)", "Windows 10", "iPhone (iOS)", "Android"])
        
        self.ua_map = {
            "Linux (Default)": self.default_ua,
            "Windows 10": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36",
            "iPhone (iOS)": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
            "Android": "Mozilla/5.0 (Linux; Android 13; Pixel 6) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Mobile Safari/537.36"
        }
        self.ua_selector.currentIndexChanged.connect(self.update_user_agent)
        self.navbar.addWidget(self.ua_selector)

        # New Tab & Nuke Button
        self.add_nav_btn("+", lambda: self.add_new_tab())
        
        self.nuke_btn = QPushButton("☢")
        self.nuke_btn.setToolTip("NUKE DATA: Delete all cookies/cache")
        self.nuke_btn.setStyleSheet("color: #ff5555; font-size: 16px; font-weight: 900;")
        self.nuke_btn.clicked.connect(self.nuke_data)
        self.navbar.addWidget(self.nuke_btn)

        # Tab Container
        self.tabs = QTabWidget()
        self.tabs.setDocumentMode(True)
        self.tabs.setTabsClosable(True)
        self.tabs.tabCloseRequested.connect(self.close_tab)
        self.tabs.currentChanged.connect(self.tab_switched)
        self.setCentralWidget(self.tabs)

        # Launch First Tab
        self.add_new_tab(QUrl("https://www.google.com"), "Home")

    def add_nav_btn(self, text, func):
        btn = QPushButton(text)
        btn.setFixedWidth(35)
        btn.clicked.connect(func)
        self.navbar.addWidget(btn)

    def add_new_tab(self, qurl=None, label="New Tab"):
        if qurl is None: qurl = QUrl("https://www.google.com")
        browser = QWebEngineView()
        browser.setUrl(qurl)
        i = self.tabs.addTab(browser, label)
        self.tabs.setCurrentIndex(i)
        
        browser.urlChanged.connect(lambda q, b=browser: self.update_url(q, b))
        browser.loadFinished.connect(lambda _, i=i, b=browser: self.tabs.setTabText(self.tabs.indexOf(b), b.page().title()))

    def tab_switched(self, i):
        if i >= 0: self.update_url(self.tabs.widget(i).url(), self.tabs.widget(i))

    def close_tab(self, i):
        if self.tabs.count() > 1: self.tabs.removeTab(i)
        else: self.navigate_to_url()

    def navigate_to_url(self):
        u = self.url_bar.text()
        if "." not in u and " " in u: u = "https://www.google.com/search?q=" + u
        elif not "://" in u: u = "https://" + u
        self.tabs.currentWidget().setUrl(QUrl(u))

    def update_url(self, q, browser=None):
        if browser == self.tabs.currentWidget():
            self.url_bar.setText(q.toString())

    def update_user_agent(self):
        selection = self.ua_selector.currentText()
        self.profile.setHttpUserAgent(self.ua_map[selection])
        if self.tabs.currentWidget():
            self.tabs.currentWidget().reload()

    def nuke_data(self):
        reply = QMessageBox.warning(self, "Nuke Data?", "Delete ALL cookies & cache? You will be logged out.",
                                    QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        if reply == QMessageBox.StandardButton.Yes:
            self.profile.clearHttpCache()
            self.profile.cookieStore().deleteAllCookies()
            print("[!] DATA NUKED.")
            self.tabs.currentWidget().reload()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyleSheet(CHROMIUM_STYLE)
    window = BotHunterBrowser()
    window.show()
    sys.exit(app.exec())
